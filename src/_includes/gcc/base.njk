<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title>{% if title %}{{ title }} — Gloucester City Council{% else %}Gloucester City Council{% endif %}</title>

    {# ── Core identity meta ── #}
    <meta name="description" content="{% if description %}{{ description }}{% elif summary %}{{ summary }}{% else %}Official Gloucester City Council information.{% endif %}">
    <meta name="author" content="Gloucester City Council">
    <meta name="publisher" content="Gloucester City Council">
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large">

    {# ── Canonical: point to production URL when available ── #}
    {% if canonical %}
    <link rel="canonical" href="{{ canonical }}">
    {% endif %}

    {# ── Open Graph (used by Perplexity, Bing Copilot, ChatGPT Browse) ── #}
    <meta property="og:title" content="{{ title }} — Gloucester City Council">
    <meta property="og:description" content="{% if description %}{{ description }}{% elif summary %}{{ summary }}{% else %}Official information from Gloucester City Council.{% endif %}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Gloucester City Council">
    {% if canonical %}
    <meta property="og:url" content="{{ canonical }}">
    {% endif %}

    {# ── JSON-LD structured data ── #}
    {% if schema_type %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "{{ schema_type }}",
      "name": "{{ title }}",
      "description": "{{ description if description else summary }}",
      "provider": {
        "@type": "GovernmentOrganization",
        "name": "Gloucester City Council",
        "url": "https://www.gloucester.gov.uk",
        "sameAs": [
          "https://www.wikidata.org/wiki/Q1247043",
          "https://en.wikipedia.org/wiki/Gloucester_City_Council"
        ],
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Eastgate Management Suite, Eastgate Street",
          "addressLocality": "Gloucester",
          "postalCode": "GL1 1PA",
          "addressCountry": "GB"
        }
      },
      "areaServed": {
        "@type": "City",
        "name": "Gloucester",
        "sameAs": "https://en.wikipedia.org/wiki/Gloucester"
      }{% if dateModified %},
      "dateModified": "{{ dateModified }}"{% endif %}{% if canonical %},
      "url": "{{ canonical }}"{% endif %}
    }
    </script>
    {% endif %}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ "/assets/gcc/tokens.css" | url }}">
    <link rel="stylesheet" href="{{ "/assets/gcc/base.css" | url }}">
    <link rel="stylesheet" href="{{ "/assets/gcc/components.css" | url }}">
    <link rel="stylesheet" href="{{ "/assets/gcc/site.css" | url }}">
    {% block head %}{% endblock %}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="gcc-site-header" role="banner">
      <div class="gcc-site-header__bar">
        <div class="gcc-container gcc-site-header__inner">
          <a href="{{ "/" | url }}" class="gcc-site-header__wordmark" aria-label="Gloucester City Council home">
            <span class="gcc-site-header__name">Gloucester City Council</span>
          </a>
          <details class="gcc-nav-toggle">
            <summary aria-label="Open navigation menu">Menu</summary>
            <ul class="gcc-primary-nav" role="list">
              <li><a href="{{ "/council-tax/" | url }}">Council Tax</a></li>
              <li><a href="{{ "/planning/" | url }}">Planning</a></li>
              <li><a href="{{ "/bins-recycling/" | url }}">Bins &amp; Recycling</a></li>
              <li><a href="{{ "/parking/" | url }}">Parking</a></li>
              <li><a href="{{ "/contact/" | url }}">Contact</a></li>
            </ul>
          </details>
        </div>
      </div>
    </header>

    <div class="gcc-phase-bar" role="complementary" aria-label="Service status">
      <div class="gcc-container gcc-phase-bar__inner">
        <strong class="gcc-phase-badge">beta</strong>
        <span class="gcc-phase-bar__text">
          This is a new service —
          <a href="{{ "/feedback/" | url }}">your feedback will help us improve it</a>.
        </span>
      </div>
    </div>

    <main id="main-content" tabindex="-1">
      {% block content %}{% endblock %}
    </main>

    <footer class="gcc-footer" role="contentinfo">
      <div class="gcc-footer__upper">
        <div class="gcc-container gcc-footer__upper-grid">
          <div>
            <a href="{{ "/" | url }}" class="gcc-footer__brand-name">Gloucester City Council</a>
            <p class="gcc-footer__tagline">Serving the people of Gloucester. Your council, online.</p>
          </div>
          <div>
            <h2 class="gcc-footer__col-heading">Services</h2>
            <ul class="gcc-footer__links" role="list">
              <li><a href="{{ "/council-tax/" | url }}">Council Tax</a></li>
              <li><a href="{{ "/planning/" | url }}">Planning</a></li>
              <li><a href="{{ "/bins-recycling/" | url }}">Bins &amp; Recycling</a></li>
              <li><a href="{{ "/parking/" | url }}">Parking</a></li>
              <li><a href="{{ "/housing/" | url }}">Housing</a></li>
            </ul>
          </div>
          <div>
            <h2 class="gcc-footer__col-heading">Council</h2>
            <ul class="gcc-footer__links" role="list">
              <li><a href="{{ "/about/" | url }}">About the council</a></li>
              <li><a href="{{ "/news/" | url }}">News</a></li>
              <li><a href="{{ "/meetings/" | url }}">Meetings &amp; decisions</a></li>
              <li><a href="{{ "/jobs/" | url }}">Jobs</a></li>
              <li><a href="{{ "/contact/" | url }}">Contact us</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="gcc-footer__lower">
        <div class="gcc-container gcc-footer__lower-inner">
          <span class="gcc-footer__copyright">&copy; Gloucester City Council {{ currentYear }}</span>
          <ul class="gcc-footer__legal" role="list">
            <li><a href="{{ "/accessibility-statement/" | url }}">Accessibility</a></li>
            <li><a href="{{ "/cookies/" | url }}">Cookies</a></li>
            <li><a href="{{ "/privacy/" | url }}">Privacy</a></li>
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>
